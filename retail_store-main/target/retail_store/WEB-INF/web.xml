<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee          https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <display-name>Electronic Store</display-name>
    <context-param>
        <param-name>org.apache.tomcat.util.scan.StandardJarScanFilter.jarsToSkip</param-name>
        <param-value>*.jar</param-value>
    </context-param>
    <listener>
        <listener-class>com.electronicstore.util.DatabaseCleanupListener</listener-class>
    </listener>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CartViewServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.CartViewServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CartViewServlet</servlet-name>
        <url-pattern>/cart</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CheckoutServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.CheckoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckoutServlet</servlet-name>
        <url-pattern>/checkout</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>PlaceOrderServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.PlaceOrderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PlaceOrderServlet</servlet-name>
        <url-pattern>/placeOrder</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ProductServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.ProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/ProductServlet</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ProductDetailServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.ProductDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductDetailServlet</servlet-name>
        <url-pattern>/ProductDetailServlet</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CartServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.CartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CartServlet</servlet-name>
        <url-pattern>/CartServlet</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>RemoveFromCartServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.RemoveFromCartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RemoveFromCartServlet</servlet-name>
        <url-pattern>/RemoveFromCartServlet</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ShopServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet.ShopServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ShopServlet</servlet-name>
        <url-pattern>/shop</url-pattern>
    </servlet-mapping>
    <!-- Admin Dashboard servlet + mapping -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/adminDashboard</url-pattern>
    </servlet-mapping>
    <!-- Admin: list all users -->
    <servlet>
        <servlet-name>AdminUserListServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.AdminUserListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUserListServlet</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>
    <!-- Admin: delete a user -->
    <servlet>
        <servlet-name>DeleteUserServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.DeleteUserServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteUserServlet</servlet-name>
        <url-pattern>/admin/deleteUser</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>AddProductServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.AddProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddProductServlet</servlet-name>
        <url-pattern>/admin/addProduct</url-pattern>
    </servlet-mapping>
    <!-- Admin: list all products -->
    <servlet>
        <servlet-name>AdminProductListServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.AdminProductListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminProductListServlet</servlet-name>
        <url-pattern>/admin/products</url-pattern>
    </servlet-mapping>
    <!-- Admin: delete a product -->
    <servlet>
        <servlet-name>DeleteProductServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.DeleteProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteProductServlet</servlet-name>
        <url-pattern>/admin/deleteProduct</url-pattern>
    </servlet-mapping>
    <!-- Admin: list and manage categories -->
    <servlet>
        <servlet-name>AdminCategoryListServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.AdminCategoryListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminCategoryListServlet</servlet-name>
        <url-pattern>/admin/categories</url-pattern>
    </servlet-mapping>
    <!-- Add Category -->
    <servlet>
        <servlet-name>AddCategoryServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.AddCategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddCategoryServlet</servlet-name>
        <url-pattern>/admin/addCategory</url-pattern>
    </servlet-mapping>
    <!-- Delete Category -->
    <servlet>
        <servlet-name>DeleteCategoryServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.DeleteCategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteCategoryServlet</servlet-name>
        <url-pattern>/admin/deleteCategory</url-pattern>
    </servlet-mapping>
    <!-- List Orders -->
    <servlet>
        <servlet-name>AdminOrderListServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.AdminOrderListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminOrderListServlet</servlet-name>
        <url-pattern>/admin/orders</url-pattern>
    </servlet-mapping>
    <!-- Mark Done -->
    <servlet>
        <servlet-name>MarkOrderDoneServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.MarkOrderDoneServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MarkOrderDoneServlet</servlet-name>
        <url-pattern>/admin/markOrderDone</url-pattern>
    </servlet-mapping>
    <!-- Delete Order -->
    <servlet>
        <servlet-name>DeleteOrderServlet</servlet-name>
        <servlet-class>com.electronicstore.servlet_admin.DeleteOrderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteOrderServlet</servlet-name>
        <url-pattern>/admin/deleteOrder</url-pattern>
    </servlet-mapping>
</web-app>
